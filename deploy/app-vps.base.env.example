APP_HOST=app.example.com
MEDIA_HOST=media.example.com
RUSTFS_ADMIN_HOST=rustfs-admin.example.com
OAUTH2_PROXY_HOST=oauth2.example.com
APP_HTTP_PORT=80
APP_HTTPS_PORT=443
RUSTFS_HTTP_PORT=8082
RUSTFS_HTTPS_PORT=9443

NEXT_PUBLIC_SITE_URL=https://app.example.com
NEXT_PUBLIC_MEDIA_BASE_URL=https://media.example.com
NEXTAUTH_URL=https://app.example.com

# If RustFS is on the same Docker host, keep S3_ENDPOINT as http://rustfs:9000
# and start RustFS before the website so the shared Docker network exists.
# If RustFS is on a separate VPS, use its private network URL instead.
S3_ENDPOINT=http://rustfs:9000
S3_PUBLIC_ENDPOINT=https://media.example.com
S3_BUCKET=public-media
S3_PRIVATE_BUCKET=private-user-files
S3_REGION=us-east-1
RUSTFS_NETWORK=rustfs_internal

KEYCLOAK_ISSUER=https://auth.example.com/realms/website
KEYCLOAK_CLIENT_ID=website
KEYCLOAK_REQUIRED_MEDIA_ROLES=owner,media_admin
KEYCLOAK_ASSET_ADMIN_ROLES=owner,asset_admin
KEYCLOAK_ROLE_CLAIM_PATH=resource_access.website.roles
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=website-admin

BAO_ADDR=https://openbao.internal.example.com
BAO_KV_MOUNT=kv
BAO_SECRET_PATH_WEBSITE=website/prod
BAO_SECRET_PATH_RUSTFS=rustfs/prod
BAO_SECRET_PATH_OAUTH2_PROXY=oauth2-proxy/prod
BAO_SECRET_PATH_KEYCLOAK=keycloak/prod

# Must match the GitHub Actions GHCR image. GHCR image paths must be lowercase.
WEBSITE_IMAGE=ghcr.io/tabeeb09/website:latest
OAUTH2_PROXY_ALLOWED_ROLE=infra_admin
OAUTH2_PROXY_REDIRECT_URL=https://oauth2.example.com/oauth2/callback
