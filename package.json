{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fetch:openbao-secrets": "node scripts/fetch-openbao-secrets.mjs",
    "seed:openbao-dev": "node scripts/seed-openbao-dev.mjs",
    "secret-refresh-relay": "node scripts/secret-refresh-relay.mjs",
    "prepare:fullstack:local": "node scripts/prepare-full-stack-env.mjs --mode local --base .env.full.local --runtime .env.runtime --output .env.full.local.generated",
    "up:fullstack:local": "node scripts/full-stack-local-up.mjs",
    "prepare:fullstack:prod": "node scripts/prepare-full-stack-env.mjs --mode prod --base .env.example --runtime .env.runtime --output .env.full.generated",
    "init:rustfs": "node scripts/init-rustfs-bucket.mjs",
    "upload:resources": "node scripts/upload-site-resources.mjs",
    "print:dev": "npm --prefix deployables/print-stage run dev",
    "print:build": "npm --prefix deployables/print-stage run build",
    "print:start": "npm --prefix deployables/print-stage run start",
    "print:worker": "npm --prefix deployables/print-stage run worker"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "bootstrap": "^5.3.0",
    "lightningcss": "^1.31.1",
    "next": "16.0.1",
    "next-auth": "^4.22.1",
    "pdfjs-dist": "^5.4.296",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-pdf": "^10.2.0",
    "reveal.js": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
